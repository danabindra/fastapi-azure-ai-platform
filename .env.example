# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=DEBUG
GIT_SHA=dev
BUILD_TIME=

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/governance
# In prod this is overridden from Key Vault; locally use the value above.

# ── Key Vault (disabled locally) ──────────────────────────────────────────────
USE_KEYVAULT=false
KEYVAULT_URL=

# ── Auth (JWT / Entra ID) – disabled locally ──────────────────────────────────
AUTH_ENABLED=false
ENTRA_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0
ENTRA_AUDIENCE=api://<CLIENT_ID>

# ── OpenTelemetry ──────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=governance-starter
# Leave blank to disable; set to App Insights connection string for Azure Monitor
APPLICATIONINSIGHTS_CONNECTION_STRING=
# Or use OTLP:
OTEL_EXPORTER_OTLP_ENDPOINT=
